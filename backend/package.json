{
  "name": "jotihunt-backend",
  "version": "1.0.0",
  "description": "Backend API for JotiHunt data aggregation",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "docker:build": "docker build -t jotihunt-backend .",
    "docker:run": "docker run -p 3001:3001 jotihunt-backend"
  },
  "dependencies": {
    "axios": "^1.6.2",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "express-rate-limit": "^7.5.1",
    "fs-extra": "^11.2.0",
    "helmet": "^7.1.0",
    "node-cache": "^5.1.2",
    "node-cron": "^3.0.3",
    "sqlite3": "^5.1.6",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.2"
  },
  "keywords": [
    "jotihunt",
    "api",
    "backend",
    "express"
  ],
  "author": "JotiHunt Team",
